class Ingredient:
    def __init__(self, name, co2_per_kg):
        self.name = name
        self.co2_per_kg = float(co2_per_kg)
        self.carbon_tax_surcharge = 0.0 # NEW: Financial tax ($) per kg of this ingredient

class Appliance:
    def __init__(self, name, kw):
        self.name = name
        self.kw = float(kw)

class RecipeStep:
    def __init__(self, name, description, appliance=None):
        self.name = name
        self.description = description
        self.appliance = appliance
        self.inputs = []
        self.time = 0.0

    def add_ingredient(self, ingredient, amount_kg, original_name=""):
        self.inputs.append({'ingredient': ingredient, 'amount': amount_kg, 'original_name': original_name})

    def set_duration(self, time_min):
        self.time = time_min

    # Add the grid_co2_per_kwh parameter (US average is ~0.385 kgCO2/kWh)
    def calculate_metrics(self, grid_co2_per_kwh=0.385):
        emissions = 0.0
        mass = 0.0
        kwh_used = 0.0
        step_tax_cost = 0.0 # NEW: Track ingredient taxes in this step
        details = {'ingredients': [], 'appliance': None}
        
        # 1. Ingredient Calculation
        for item in self.inputs:
            ing = item['ingredient']
            amt = item['amount']
            orig = item['original_name']
            
            ing_emissions = amt * ing.co2_per_kg
            ing_tax = amt * ing.carbon_tax_surcharge # Calculate the financial penalty
            print(amt, ing.carbon_tax_surcharge)
            
            emissions += ing_emission
            step_tax_cost += ing_tax
            mass += amt
            
            details['ingredients'].append({
                'original': orig,
                'mapped': ing.name,
                'amount': amt,
                'emission': ing_emissions,
                'tax_cost': ing_tax
            })
            
        # 2. Energy & Emissions Calculation
        if self.appliance and self.time > 0 and self.appliance.name != "Prep Table":
            kwh_used = self.appliance.kw * (self.time / 60.0)
            app_emissions = kwh_used * grid_co2_per_kwh
            emissions += app_emission
            
            details['appliance'] = {
                'name': self.appliance.name,
                'time_min': self.time,
                'kwh': kwh_used,
                'emission': app_emission
            }
        
        return {
            'emissions': emissions, 
            'mass': mass,
            'time': self.time,
            'kwh': kwh_used,
            'tax_cost': step_tax_cost, # Return the tax up to the Recipe
            'details': details
        }

class Recipe:
    def __init__(self, name, price):
        self.name = name
        self.price = price
        self.steps = []

    def add_step(self, step):
        self.steps.append(step)

    def evaluate(self, labor_rate_per_min=0.25, electricity_price_per_kwh=0.20, grid_co2_per_kwh=0.385):
        total = {'emissions': 0.0, 'time': 0.0, 'mass': 0.0, 'kwh': 0.0, 'tax_cost': 0.0}
        breakdown = []
        labor_time = 0.0
        
        for step in self.steps:
            m = step.calculate_metrics(grid_co2_per_kwh)
            
            total['emissions'] += m['emissions']
            total['time'] += m['time']
            total['mass'] += m['mass']
            total['kwh'] += m['kwh'] 
            total['tax_cost'] += m['tax_cost'] # Accumulate the new tax
            
            if step.appliance is None or step.appliance.name == "Prep Table":
                labor_time += m['time']
                
            breakdown.append({
                'step_name': step.name,
                'description': step.description,
                'step_emissions': m['emissions'],
                'details': m['details']
            })
            
        food_cost = self.price * 0.30
        labor_cost = labor_time * labor_rate_per_min
        appliance_cost = total['kwh'] * electricity_price_per_kwh
        carbon_tax = total['tax_cost']
        
        # Net Profit now deducts the actual Carbon Tax
        # print(carbon_tax, self.price)
        net_profit = self.price - food_cost - labor_cost - appliance_cost - carbon_tax
        
        return {
            'Dish': self.name,
            'Price': self.price,
            'Food_Cost': round(food_cost, 2),
            'Labor_Cost': round(labor_cost, 2),
            'Appliance_Cost': round(appliance_cost, 3), 
            'Carbon_Tax': round(carbon_tax, 2), # Expose this for your plots
            'Net_Profit': round(net_profit, 2),
            'Emissions': round(total['emissions'], 3),
            'Time': round(total['time'], 1),
            'Prep_Time': round(labor_time, 1),
            'Mass_KG': round(total['mass'], 2),
            'Breakdown': breakdown
        }

